# Copy to .env for local development:  cp .env.example .env

# SQL warehouse HTTP path — required for Databricks SQL queries.
DATABRICKS_SQL_WAREHOUSE_HTTP_PATH=/sql/1.0/warehouses/REPLACE_WITH_YOUR_WAREHOUSE_ID

# Unity Catalog target. Catalog must exist with CREATE SCHEMA / CREATE TABLE privileges.
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=data_collector

# Databricks CLI/SDK auth profile (from ~/.databrickscfg). Omit for DEFAULT profile.
DATABRICKS_CONFIG_PROFILE=DEFAULT
