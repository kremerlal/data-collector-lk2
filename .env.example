# Copy to .env for local development:  cp .env.example .env

# Workspace URL and personal access token
DATABRICKS_HOST=https://fevm-serverless-stable-tgnklq.cloud.databricks.com
DATABRICKS_TOKEN=REPLACE_WITH_YOUR_TOKEN

# SQL warehouse — use id OR full HTTP path
DATABRICKS_WAREHOUSE_ID=3c333bc7e0c36cd6
DATABRICKS_SQL_WAREHOUSE_HTTP_PATH=/sql/1.0/warehouses/3c333bc7e0c36cd6

# Unity Catalog target for app metadata tables
DATABRICKS_CATALOG=serverless_stable_tgnklq_catalog
DATABRICKS_SCHEMA=data_collector

# Default catalog/schema for new collection record tables (optional; falls back to values above)
# DATABRICKS_DEFAULT_DATA_CATALOG=my_data_catalog
# DATABRICKS_DEFAULT_DATA_SCHEMA=my_data_schema

# Genie Q&A (enabled by default; uses DATABRICKS_WAREHOUSE_ID)
# GENIE_ENABLED=true
# Optional workspace folder for Genie spaces (auto-created if missing; NOT Unity Catalog)
# GENIE_PARENT_PATH=/Data Collector

# Foundation Model API endpoint (Serving tab → Foundation Model APIs)
DATABRICKS_FM_ENDPOINT=databricks-meta-llama-3-3-70b-instruct

# Databricks CLI profile (optional) — used by scripts/deploy.sh
# DATABRICKS_CONFIG_PROFILE=DEFAULT

# Workspace folder for bundle deploy (default /Workspace/DBRX-Apps; created if missing)
# DATABRICKS_DEPLOY_FOLDER=/Workspace/DBRX-Apps

# Override deployed app name (default data-collector-dev / data-collector-prod)
# DATABRICKS_APP_NAME=data-collector-dev

# Lakebase app resource (prod deploy re-attaches automatically via deploy.sh)
# LAKEBASE_BRANCH=projects/data-collector/branches/production
# LAKEBASE_DATABASE=projects/data-collector/branches/production/databases/databricks-postgres
# ENSURE_LAKEBASE_APP_RESOURCE=true

# Lakebase (optional) — for collections with storage_type=lakebase
# PGHOST=ep-xxxx.database.us-west-2.dev.databricks.com
# PGDATABASE=databricks_postgres
# PGUSER=your.email@company.com
# PGPORT=5432
# PGSSLMODE=require
# ENDPOINT_NAME=projects/<project-id>/branches/<branch-id>/endpoints/<endpoint-id>
# LAKEBASE_DEFAULT_SCHEMA=data_collector
